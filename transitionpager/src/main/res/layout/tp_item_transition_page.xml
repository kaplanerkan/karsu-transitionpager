<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <com.karsu.transitionpager.DragLayout
        android:id="@+id/tp_drag_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        app:bottomDragVisibleHeight="@dimen/tp_card_bottom_info_height"
        app:bottomExtraIndicatorHeight="@dimen/tp_card_extra_height">

        <!-- 1) Alt bilgi paneli (başlangıçta alpha=0) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/tp_bottom_panel_height"
            android:layout_gravity="center_vertical"
            android:alpha="0"
            android:background="@drawable/tp_bottom_panel_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/tp_card_bottom_info_height"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tp_bottom_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#222222"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Mountain Lake" />

                <TextView
                    android:id="@+id/tp_bottom_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    tools:text="Bergen, Norway" />

                <RatingBar
                    android:id="@+id/tp_bottom_rating"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:isIndicator="true"
                    android:numStars="5" />

            </LinearLayout>
        </FrameLayout>

        <!-- 2) Üst sürüklenebilir kart -->
        <com.karsu.transitionpager.AspectRatioCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="@dimen/tp_card_extra_height"
            app:cardCornerRadius="10dp"
            app:cardElevation="8dp">

            <ImageView
                android:id="@+id/tp_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#222222"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom"
                android:background="@drawable/tp_scrim" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tp_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:shadowColor="#88000000"
                    android:shadowRadius="4"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="Mountain Lake" />

                <TextView
                    android:id="@+id/tp_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:shadowColor="#88000000"
                    android:shadowRadius="4"
                    android:textColor="#EEEEEE"
                    android:textSize="13sp"
                    tools:text="Bergen, Norway" />

                <RatingBar
                    android:id="@+id/tp_rating"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:isIndicator="true"
                    android:numStars="5" />

            </LinearLayout>

        </com.karsu.transitionpager.AspectRatioCardView>

    </com.karsu.transitionpager.DragLayout>

</FrameLayout>
